{
  "version": 2,
  "builds": [
    {
      "src": "proj-carros-frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "proj-carro-backend/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "proj-carro-backend/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "proj-carros-frontend/$1"
    }
  ]
}