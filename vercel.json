{
  "version": 2,
  "builds": [
    {
      "src": "proj-carros-frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "proj-carro-backend/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "proj-carro-backend/api/index.ts"
    }
  ]
}